# ---- Dependencies (reinstall on the server with `npm ci`) ----
/node_modules
/.pnp
.pnp.js

# ---- Next.js build output (regenerated with `npm run build`) ----
/.next/
/out/
/build

# ---- TypeScript build cache ----
*.tsbuildinfo

# ---- Secrets: NEVER commit. Recreate these by hand on the server ----
.env
.env*.local
.env.production
openai_config.json
SendGrid_API.txt
!.env.example

# ---- Logs & debug ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# ---- Local-only helpers ----
check-deps.ps1
check-deps.sh
