# PRODUCTION env — on the server, copy this to `.env` (next to docker-compose.prod.yml) and fill it.
# IMPORTANT: the password in DATABASE_URL must be the SAME as POSTGRES_PASSWORD.

# Postgres (the password is used by the db container AND by DATABASE_URL below)
POSTGRES_PASSWORD=pon_una_clave_fuerte

# Inside Docker, the DB host is "db" and Redis is "redis" (service names), not localhost
DATABASE_URL=postgresql://postgres:pon_una_clave_fuerte@db:5432/heropath
REDIS_URL=redis://redis:6379

# Public URL — used to build the links inside the emails
NEXT_PUBLIC_BASE_URL=https://heropath.tuzzi.ai

# App master password (elige una fuerte para producción)
APP_PASSWORD=cambia_esto_por_algo_fuerte

# LLM (proveedor compatible con OpenAI). Para DeepSeek:
LLM_API_KEY=sk-...                       # tu API key de DeepSeek
LLM_BASE_URL=https://api.deepseek.com    # base URL del proveedor
LLM_MODEL=deepseek-v4-flash              # id exacto del modelo
# (Alternativa OpenAI: deja LLM_* vacías y usa OPENAI_API_KEY)
# OPENAI_API_KEY=sk-...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@tuzzi.ai
